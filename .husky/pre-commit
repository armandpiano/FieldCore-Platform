#!/usr/bin/env sh
# Pre-commit hook - runs lint-staged on staged files

echo "🔍 Running pre-commit checks..."

# Check if lint-staged is installed
if ! command -v lint-staged &> /dev/null; then
    echo "⚠️  lint-staged not found. Running npx..."
    npx lint-staged
else
    lint-staged
fi

# Get the exit code
RESULT=$?

if [ $RESULT -eq 0 ]; then
    echo "✅ Pre-commit checks passed!"
else
    echo "❌ Pre-commit checks failed!"
    echo ""
    echo "Please fix the errors above before committing."
    echo "Tip: You can use 'npm run lint:fix' or 'npm run format' to auto-fix some issues."
fi

exit $RESULT
