# FieldCore API Environment Variables

# Application
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
API_PREFIX=api
CORS_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fieldcore?schema=public
DATABASE_LOG=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=fieldcore-evidence
S3_ENDPOINT=http://localhost:9000

# Logging
LOG_LEVEL=log
