# ============================================
# FieldCore Environment Configuration
# ============================================
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control
# ============================================

# ===== Application Mode =====
NODE_ENV=development
# Options: development, staging, production

# ===== Ports =====
WEB_PORT=3000
API_PORT=3001
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
NGINX_PORT=80
NGINX_SSL_PORT=443

# ===== PostgreSQL =====
POSTGRES_DB=fieldcore
POSTGRES_USER=fieldcore
POSTGRES_PASSWORD=your_secure_password_here

# ===== Redis =====
# No password for local development
REDIS_PASSWORD=

# ===== MinIO (S3 Compatible) =====
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_secure_minio_password_here

# ===== JWT Authentication =====
# IMPORTANT: Change these in production!
JWT_SECRET=your_jwt_secret_key_min_32_chars_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_min_32_chars_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ===== S3 / Cloud Storage =====
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=fieldcore-evidence
# For production, use AWS S3 or other S3-compatible service:
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_ACCESS_KEY=your_aws_access_key
# S3_SECRET_KEY=your_aws_secret_key

# ===== CORS =====
CORS_ORIGIN=http://localhost:3000

# ===== Frontend URLs =====
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===== Email (Optional - for notifications) =====
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@fieldcore.app

# ===== BullMQ / Job Queues =====
# REDIS_HOST=redis
# REDIS_PORT=6379

# ===== Logging =====
LOG_LEVEL=debug
# Options: debug, info, warn, error

# ===== Feature Flags =====
ENABLE_DOCS=true
ENABLE_METRICS=true
