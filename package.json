{
  "name": "fieldcore-platform",
  "version": "0.0.1",
  "private": true,
  "description": "SaaS B2B platform for field operations management",
  "author": "Armando Vazquez <armancma777@gmail.com>",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/armandpiano/FieldCore-Platform"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    // ====================
    // Development
    // ====================
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=web",
    "dev:api": "turbo dev --filter=api",
    "dev:all": "concurrently \"pnpm dev:api\" \"pnpm dev:web\"",
    
    // ====================
    // Building
    // ====================
    "build": "turbo build",
    "build:web": "turbo build --filter=web",
    "build:api": "turbo build --filter=api",
    "build:prod": "turbo build --filter=...!web",
    
    // ====================
    // Testing
    // ====================
    "test": "turbo test",
    "test:watch": "turbo test -- --watch",
    "test:coverage": "turbo test -- --coverage",
    "test:ci": "turbo test -- --ci --coverage",
    "test:e2e": "cd apps/api && pnpm test:e2e",
    "test:api": "cd apps/api && pnpm test",
    "test:web": "cd apps/web && pnpm test",
    
    // ====================
    // Linting & Formatting
    // ====================
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "lint:staged": "lint-staged",
    "lint:eslint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:eslint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,jsonc,md,mdx,css,scss,yaml,yml,sql}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,jsonc,md,mdx,css,scss,yaml,yml,sql}\"",
    "format:web": "cd apps/web && pnpm format",
    "format:api": "cd apps/api && pnpm format",
    
    // ====================
    // Type Checking
    // ====================
    "typecheck": "turbo typecheck",
    "typecheck:web": "cd apps/web && pnpm typecheck",
    "typecheck:api": "cd apps/api && pnpm typecheck",
    
    // ====================
    // Database
    // ====================
    "db:migrate": "cd apps/api && pnpm db:migrate",
    "db:migrate:dev": "cd apps/api && pnpm db:migrate:dev",
    "db:migrate:deploy": "cd apps/api && pnpm db:migrate:deploy",
    "db:seed": "cd apps/api && pnpm db:seed",
    "db:studio": "cd apps/api && pnpm db:studio",
    "db:reset": "cd apps/api && pnpm db:reset",
    "db:generate": "cd apps/api && pnpm db:generate",
    "db:push": "cd apps/api && pnpm db:push",
    
    // ====================
    // Git Hooks
    // ====================
    "prepare": "husky install",
    "commit": "cz",
    "verify": "pnpm lint && pnpm typecheck && pnpm test",
    "verify:staged": "pnpm lint:staged",
    
    // ====================
    // Docker
    // ====================
    "docker:up": "cd infrastructure/docker && docker-compose up -d",
    "docker:down": "cd infrastructure/docker && docker-compose down",
    "docker:build": "cd infrastructure/docker && docker-compose build",
    "docker:logs": "cd infrastructure/docker && docker-compose logs -f",
    "docker:ps": "cd infrastructure/docker && docker-compose ps",
    "docker:clean": "cd infrastructure/docker && docker-compose down -v --rmi local",
    
    // ====================
    // Cleanup
    // ====================
    "clean": "turbo run clean",
    "clean:deps": "rm -rf node_modules apps/*/node_modules packages/*/node_modules",
    "clean:cache": "turbo run clean && rm -rf .turbo .next .vercel",
    "clean:all": "pnpm clean && pnpm clean:deps && pnpm clean:cache",
    
    // ====================
    // CI/CD
    // ====================
    "ci:install": "pnpm install --frozen-lockfile",
    "ci:audit": "pnpm audit --audit-level=high",
    "ci:lint": "pnpm lint",
    "ci:typecheck": "pnpm typecheck",
    "ci:test": "pnpm test:ci",
    "ci:build": "pnpm build",
    "ci:validate": "pnpm ci:audit && pnpm ci:lint && pnpm ci:typecheck && pnpm ci:test",
    
    // ====================
    // Release
    // ====================
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:patch": "standard-version --release-as patch"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.18.0",
    "@typescript-eslint/parser": "^6.18.0",
    "typescript": "^5.3.3",
    "turbo": "^1.11.3",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "@commitlint/cli": "^18.4.3",
    "@commitlint/config-conventional": "^18.4.3",
    "prettier": "^3.1.1",
    "eslint": "^8.56.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-unused-imports": "^3.0.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "jest-junit": "^16.0.0",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.2",
    "concurrently": "^8.2.2",
    "standard-version": "^9.5.0",
    "cz-conventional-changelog": "^3.3.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "packageManager": "pnpm@8.10.5",
  "pnpm": {
    "overrides": {
      "typescript": "^5.3.3"
    }
  }
}
